%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart TB

    %% ─── Governance moments ───
    PROPOSAL([Proposal Submission])
    EXCEPTION([Exception Request])
    INCIDENT([Post-Incident])
    AUDIT([Periodic Audit])

    %% ─── Distinct checklists per moment ───
    subgraph CHECKLISTS [Governance Checklists &mdash; one per moment]
        direction TB
        CL_PROP[Proposal-Review<br/>well-formed? alternatives?<br/>standards aligned?]
        CL_EXC[Exception-Review<br/>bounded scope?<br/>revisit cadence?]
        CL_INC[Post-Incident<br/>did process catch risk?<br/>what should change?]
        CL_AUD[Audit<br/>quarterly &middot; trends<br/>process health]
    end

    %% ─── Each checklist owned and reviewed ───
    OWNERS[(Documented Owners<br/>review cadence<br/>versioned changes)]

    %% ─── Workflow integration ───
    subgraph WORKFLOW [Workflow Integration]
        direction LR
        ADR_REPO[ADR Repository<br/>checklist embedded<br/>in templates]
        PR_TPL[PR / RFC Templates<br/>checklist as required fields]
        ARB_AGENDA[ARB Agenda Tool<br/>opening + closing checklists]
    end

    %% ─── Application telemetry ───
    TELEMETRY[/Application Rate<br/>completion %<br/>reviewer attestation/]

    %% ─── Feedback loops ───
    FEEDBACK[Item Lifecycle<br/>add &middot; refine &middot; retire]
    INSTITUTIONAL[(Institutional Memory<br/>incidents &middot; audit findings<br/>regulator questions)]

    %% ─── Flow ───
    PROPOSAL --> CL_PROP
    EXCEPTION --> CL_EXC
    INCIDENT --> CL_INC
    AUDIT --> CL_AUD

    CHECKLISTS --> WORKFLOW
    OWNERS -.governs.-> CHECKLISTS

    WORKFLOW --> TELEMETRY
    TELEMETRY -.signals.-> FEEDBACK

    %% ─── Institutional memory feedback ───
    CL_INC -.surfaces lessons.-> INSTITUTIONAL
    CL_AUD -.surfaces gaps.-> INSTITUTIONAL
    INSTITUTIONAL -.adds items.-> FEEDBACK
    FEEDBACK -.evolves.-> CHECKLISTS

    %% ─── NODE STYLES ───
    style PROPOSAL  fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style EXCEPTION fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style INCIDENT  fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style AUDIT     fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Checklists: emphasised cream (the architectural artefacts)
    style CL_PROP fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style CL_EXC  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style CL_INC  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style CL_AUD  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410

    %% Owners: blue (the governance discipline)
    style OWNERS fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Workflow integration: amber (where governance meets engineering)
    style ADR_REPO   fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style PR_TPL     fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style ARB_AGENDA fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Telemetry / feedback: cooler tone
    style TELEMETRY     fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C
    style FEEDBACK      fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.6px,color:#2C4258
    style INSTITUTIONAL fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.6px,color:#2C4258

    %% ─── CLUSTER STYLES ───
    style CHECKLISTS fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
    style WORKFLOW   fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
