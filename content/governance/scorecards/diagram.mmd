%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart TB

    %% ─── Data sources ───
    subgraph SOURCES [Data Sources]
        direction TB
        DECISIONS[(Decision System Telemetry<br/>submissions &middot; reviews &middot; outcomes)]
        AUDITS[(Sampled Audits<br/>retrospective reviews)]
        AUTO[(Automated Checks<br/>code &middot; infra-as-code &middot; runtime)]
    end

    %% ─── Two measurement streams ───
    subgraph PROCESS [Process Metrics &mdash; responsiveness]
        direction TB
        LEAD[Lead Time<br/>per decision class<br/>vs SLA]
        QUEUE[Queue Depth<br/>open decisions<br/>time-in-queue]
        THRU[Throughput<br/>completions per period]
    end

    subgraph OUTCOME [Outcome Metrics &mdash; quality]
        direction TB
        QUALITY[Decision Quality<br/>retrospective review<br/>independent reviewers]
        EXC[Exception Rate<br/>per standard<br/>not aggregated]
        ADOPT[Adoption Rate<br/>actual deployment<br/>vs paper compliance]
    end

    %% ─── Cadence layer ───
    CADENCE{Cadence Layer<br/>per-metric review frequency<br/>operational weekly &middot; strategic quarterly}

    %% ─── Scorecard ───
    SCORECARD[(Governance Scorecard<br/>weighted toward outcomes<br/>patterns over individuals)]

    %% ─── Alerts and triggers ───
    ALERTS[/Threshold Alerts<br/>structural triggers/]

    %% ─── Feedback into governance system ───
    subgraph TUNING [Governance System Tuning]
        direction TB
        ROLES_FB[Role Structure<br/>capacity adjustments]
        STD_FB[Standards Review<br/>fix mismatched rules]
        TPL_FB[Template / Checklist<br/>add or retire items]
    end

    %% ─── Flow ───
    DECISIONS --> LEAD
    DECISIONS --> QUEUE
    DECISIONS --> THRU
    AUDITS --> QUALITY
    DECISIONS --> EXC
    AUTO --> ADOPT
    AUDITS --> ADOPT

    PROCESS --> CADENCE
    OUTCOME --> CADENCE
    CADENCE --> SCORECARD
    SCORECARD --> ALERTS

    ALERTS -.lead time issue.-> ROLES_FB
    ALERTS -.exception rate issue.-> STD_FB
    ALERTS -.decision quality issue.-> TPL_FB
    ALERTS -.adoption gap.-> STD_FB

    %% ─── Tuning feeds back into the system being measured ───
    TUNING -.adjusts.-> DECISIONS

    %% ─── NODE STYLES ───
    %% Sources: blue (operational data)
    style DECISIONS fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style AUDITS    fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style AUTO      fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Process metrics: amber (the operational signals)
    style LEAD  fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style QUEUE fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style THRU  fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Outcome metrics: emphasised cream (the architectural priority)
    style QUALITY fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style EXC     fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style ADOPT   fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410

