%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart LR

    %% ─── Artefact classes ───
    PROPOSAL([Proposal])
    DECISION([Committed Decision])
    SPEC([Design Spec])
    EXCEPTION([Exception])
    POSTINC([Post-Incident])

    %% ─── Templates ───
    subgraph TEMPLATES [Distinct Templates per Artefact Class]
        direction TB
        T_RFC[RFC Template<br/>motivation &middot; proposal<br/>alternatives &middot; open questions]
        T_ADR[ADR Template<br/>status &middot; context<br/>decision &middot; consequences]
        T_SPEC[Design Spec<br/>requirements &middot; design<br/>implementation &middot; testing]
        T_EXC[Exception Template<br/>standard &middot; why &middot; bounded scope<br/>revisit cadence]
        T_PI[Post-Incident<br/>timeline &middot; root cause<br/>actions &middot; lessons]
    end

    %% ─── Metadata layer (closed vocabulary) ───
    METADATA[(Metadata Layer<br/>status &middot; date &middot; owner<br/>supersession &middot; scope tags)]

    %% ─── Archive ───
    ARCHIVE[(Versioned Archive<br/>markdown &middot; version-controlled<br/>indexed metadata)]

    %% ─── Lifecycle ───
    LIFECYCLE{Lifecycle<br/>relationships}

    %% ─── Review surface ───
    subgraph REVIEW [Submitter-Reviewer Contract]
        direction TB
        SUB[Submitter<br/>addresses template's questions]
        REV[Reviewer<br/>evaluates within template's scope]
    end

    %% ─── Discovery / query ───
    QUERY[(Discovery Layer<br/>find by status &middot; scope &middot; date<br/>supersession chains)]

    %% ─── Flow ───
    PROPOSAL --> T_RFC
    DECISION --> T_ADR
    SPEC --> T_SPEC
    EXCEPTION --> T_EXC
    POSTINC --> T_PI

    TEMPLATES --> METADATA
    METADATA --> ARCHIVE

    %% ─── Lifecycle edges between templates ───
    T_RFC -.proposal accepted.-> LIFECYCLE
    LIFECYCLE -.becomes.-> T_ADR
    T_ADR -.superseded by.-> T_ADR
    T_PI -.surfaces update to.-> T_ADR

    %% ─── Review contract ───
    SUB -->|fills| TEMPLATES
    TEMPLATES -->|surface for| REV
    REV -.feedback.-> TEMPLATES

    %% ─── Discovery ───
    ARCHIVE --> QUERY

    %% ─── NODE STYLES ───
    style PROPOSAL  fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style DECISION  fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style SPEC      fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style EXCEPTION fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style POSTINC   fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Templates: emphasised cream (the architectural artefacts)
    style T_RFC  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style T_ADR  fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410
    style T_SPEC fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style T_EXC  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style T_PI   fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410

    %% Metadata + archive: blue (operational infrastructure)
    style METADATA fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840
    style ARCHIVE  fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840

    %% Lifecycle: amber (the dynamic relationships)
    style LIFECYCLE fill:#FEF3C7,stroke:#C96330,stroke-width:2px,color:#5C4316

    %% Review surface: cooler tone
    style SUB fill:#F4E5DD,stroke:#A37050,stroke-width:1.6px,color:#3A2410
    style REV fill:#F4E5DD,stroke:#A37050,stroke-width:1.6px,color:#3A2410

    %% Discovery: grey
    style QUERY fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C

    %% ─── CLUSTER STYLES ───
    style TEMPLATES fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
    style REVIEW    fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
