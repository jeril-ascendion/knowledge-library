%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart LR

    %% ─── Decision classes (input) ───
    subgraph CLASSES [Decision Classes]
        direction TB
        ROUTINE([Routine Tech Choice])
        CROSSCUT([Cross-Cutting Standard])
        HIGH_STAKES([High-Stakes Decision<br/>regulatory &middot; financial])
    end

    %% ─── RACI routing ───
    RACI{RACI Matrix<br/>per decision class}

    %% ─── Three authority tiers ───
    subgraph TIERS [Authority Tiers]
        direction TB
        TIER_EXEC[Executive<br/>CTO &middot; CIO &middot; CISO<br/>regulatory &middot; strategic]
        TIER_ARB[ARB<br/>composition &middot; terms<br/>recusal &middot; quorum]
        TIER_TEAM[Team<br/>routine pattern selection<br/>service-internal architecture]
    end

    %% ─── Consulted roles ───
    subgraph CONSULTED [Consulted Roles]
        direction TB
        SECURITY[Security Architect]
        LEGAL[Legal / Compliance]
        FINANCE[Finance / FinOps]
        DATA[Data Architect]
    end

    %% ─── Capacity layer ───
    CAPACITY[/Capacity Telemetry<br/>lead time &middot; queue depth<br/>review hours/]

    %% ─── Outputs ───
    ADR[(ADR / Decision Record<br/>with role attribution)]
    PROMOTE{Decision authority<br/>promotion review<br/>periodic}

    %% ─── Flow ───
    CLASSES --> RACI
    RACI -->|routine| TIER_TEAM
    RACI -->|cross-cutting| TIER_ARB
    RACI -->|high-stakes| TIER_EXEC

    %% ─── Consults run across tiers ───
    TIER_TEAM -.advice.-> SECURITY
    TIER_ARB -.consult.-> SECURITY
    TIER_ARB -.consult.-> DATA
    TIER_EXEC -.consult.-> LEGAL
    TIER_EXEC -.consult.-> FINANCE

    %% ─── Escalation up ───
    TIER_TEAM -.escalate.-> TIER_ARB
    TIER_ARB -.escalate.-> TIER_EXEC

    %% ─── All tiers produce decisions ───
    TIER_TEAM --> ADR
    TIER_ARB --> ADR
    TIER_EXEC --> ADR

    %% ─── Capacity feedback ───
    TIERS -.measured.-> CAPACITY
    CAPACITY -.signals.-> PROMOTE
    PROMOTE -.shifts authority.-> RACI

    %% ─── NODE STYLES ───
    style ROUTINE     fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style CROSSCUT    fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style HIGH_STAKES fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% RACI: emphasised cream (the routing decision)
    style RACI fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Authority tiers: amber gradient (low to high authority)
    style TIER_TEAM fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style TIER_ARB  fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style TIER_EXEC fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410

    %% Consulted: blue (advisory roles)
    style SECURITY fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.5px,color:#1A2840
    style LEGAL    fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.5px,color:#1A2840
    style FINANCE  fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.5px,color:#1A2840
    style DATA     fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.5px,color:#1A2840

    %% Capacity / promotion: cooler tone
    style CAPACITY fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C
    style PROMOTE  fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.8px,color:#2C4258

    %% Output
    style ADR fill:#F4E5DD,stroke:#A37050,stroke-width:1.6px,color:#3A2410

    %% ─── CLUSTER STYLES ───
    style CLASSES   fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
    style TIERS     fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
    style CONSULTED fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
