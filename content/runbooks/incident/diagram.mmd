%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart LR

    %% ─── Alerting layer (the trigger point) ───
    ALERT[(Alert Fires<br/>specific signature)]

    %% ─── Incident class taxonomy ───
    TAXONOMY{Incident Class<br/>Taxonomy}

    %% ─── Runbook structure ───
    subgraph RUNBOOK [Runbook per Class &mdash; designed artefact]
        direction TB
        TRIGGER[Trigger Condition<br/>alert name &middot; dashboard signature<br/>threshold value]
        STEPS[Executable Steps<br/>imperative &middot; concrete artefacts<br/>commands &middot; queries &middot; URLs]
        BRANCH{Branching<br/>for known unknowns}
        VERIFY[Verification<br/>per-step + resolution<br/>defined]
    end

    %% ─── Discoverability ───
    LINK[/Alert-to-Runbook Link<br/>embedded in alert payload/]
    TOOLING[(Integrated Tooling<br/>chat &middot; incident system<br/>alerting platform)]

    %% ─── Lifecycle ───
    STATUS{Lifecycle Status<br/>proposed &middot; in-use &middot; deprecated}

    %% ─── Learning loop ───
    INVOCATION([Runbook Invoked])
    FINDINGS[(Post-Incident Findings<br/>what was unclear / wrong / missing)]
    REVISION[Revision Queue<br/>versioned &middot; reviewed]

    %% ─── Outcomes ───
    RESOLVED([Incident Resolved])

    %% ─── Flow ───
    ALERT --> LINK
    LINK --> RUNBOOK
    ALERT -.classified by.-> TAXONOMY
    TAXONOMY -.maps to.-> RUNBOOK

    TRIGGER --> STEPS
    STEPS --> BRANCH
    BRANCH --> STEPS
    STEPS --> VERIFY
    VERIFY --> RESOLVED

    RUNBOOK -.in.-> TOOLING

    %% ─── Lifecycle attached to each runbook ───
    STATUS -.tags.-> RUNBOOK

    %% ─── Learning loop ───
    RESOLVED --> INVOCATION
    INVOCATION --> FINDINGS
    FINDINGS --> REVISION
    REVISION -.updates.-> RUNBOOK
    REVISION -.may evolve.-> TAXONOMY

    %% ─── NODE STYLES ───
    style ALERT fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Taxonomy: emphasised cream (the organising principle)
    style TAXONOMY fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Runbook structure: emphasised cream (the architectural artefact)
    style TRIGGER fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style STEPS   fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410
    style BRANCH  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style VERIFY  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410

    %% Discoverability: amber (the routing layer)
    style LINK    fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style TOOLING fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316

    %% Lifecycle: blue
    style STATUS fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Learning loop: cooler tone (the meta layer)
    style INVOCATION fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style FINDINGS   fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.6px,color:#2C4258
    style REVISION   fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.8px,color:#2C4258

    style RESOLVED fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% ─── CLUSTER STYLES ───
    style RUNBOOK fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
