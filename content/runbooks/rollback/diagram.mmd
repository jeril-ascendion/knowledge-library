%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart TB

    %% ─── Change classification ───
    CHANGE([Change Proposed])
    CLASSIFY{Reversibility<br/>Classification}

    %% ─── Two paths ───
    subgraph FORWARD_ONLY [Forward-Only Path]
        direction TB
        FO_DEPLOY[Cautious Deploy<br/>more soak &middot; more verification<br/>conservative breakpoints]
        FO_ALERT[Enhanced Alerting<br/>extended window]
    end

    subgraph REVERSIBLE [Reversible Path]
        direction TB
        SUBSTRATE{Delivery Substrate}
        FF[Feature Flag<br/>seconds-scale rollback]
        BG[Blue-Green<br/>minutes-scale rollback]
        CAN[Canary + Auto-Rollback<br/>signal-driven]
    end

    %% ─── State considerations ───
    STATE[(State Considerations<br/>schema patterns &middot; idempotency<br/>backwards-compat reads)]

    %% ─── Production ───
    PROD([Production])

    %% ─── Incident ───
    INCIDENT{{Issue Detected}}

    %% ─── Decision ───
    DECISION{Rollback vs<br/>Forward-Fix<br/>documented criteria}

    %% ─── Rollback execution ───
    subgraph ROLLBACK_RB [Rollback Runbook]
        direction TB
        INVOKE[Invoke Rollback Path<br/>flag flip / slot switch / revert]
        VERIFY_RB[Verify Rollback<br/>error rate &middot; latency<br/>state consistency]
    end

    %% ─── Forward-fix execution ───
    FORWARD_FIX[Forward Fix<br/>deploy correction]

    %% ─── Rollback exercises (the validation loop) ───
    EXERCISES[/Rollback Exercises<br/>game days &middot; staging<br/>cadence-driven/]

    %% ─── Outcomes ───
    RECOVERED([System Restored])

    %% ─── Flow ───
    CHANGE --> CLASSIFY
    CLASSIFY -->|forward-only| FORWARD_ONLY
    CLASSIFY -->|reversible| REVERSIBLE
    SUBSTRATE -->|fast| FF
    SUBSTRATE -->|medium| BG
    SUBSTRATE -->|automated| CAN
    STATE -.governs.-> CLASSIFY
    FORWARD_ONLY --> PROD
    REVERSIBLE --> PROD
    PROD -->|all good| RECOVERED
    PROD -.problem.-> INCIDENT
    INCIDENT --> DECISION
    DECISION -->|rollback| ROLLBACK_RB
    DECISION -->|forward-fix| FORWARD_FIX
    INVOKE --> VERIFY_RB
    VERIFY_RB --> RECOVERED
    FORWARD_FIX --> RECOVERED

    %% Exercises validate the runbook before incident
    EXERCISES -.validates.-> ROLLBACK_RB

    %% Auto-rollback bypasses human decision
    CAN -.auto-rollback.-> INVOKE

    %% ─── NODE STYLES ───
    style CHANGE     fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style PROD       fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style RECOVERED  fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Classification: emphasised cream
    style CLASSIFY fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Forward-only path: cooler tone (the more cautious branch)
    style FO_DEPLOY fill:#F2F4F7,stroke:#9CB0C4,stroke-width:1.5px,color:#2C4258
    style FO_ALERT  fill:#F2F4F7,stroke:#9CB0C4,stroke-width:1.5px,color:#2C4258

    %% Reversible path: emphasised cream (the architectural payoff)
    style SUBSTRATE fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style FF        fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style BG        fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style CAN       fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410

    %% State: blue (the cross-cutting concern)
    style STATE fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Incident: warm
    style INCIDENT fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410

    %% Decision: emphasised
    style DECISION fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Rollback runbook: emphasised
    style INVOKE    fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style VERIFY_RB fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410

    %% Forward-fix
    style FORWARD_FIX fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316

    %% Exercises: cooler tone
    style EXERCISES fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.6px,color:#2C4258

    %% ─── CLUSTER STYLES ───
    style FORWARD_ONLY fill:#F2F4F7,stroke:#9CB0C4,stroke-width:1.2px,color:#2C4258
    style REVERSIBLE   fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
    style ROLLBACK_RB  fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
