%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart TB

    %% ─── Input ───
    INPUT([Input<br/>code change &middot; config<br/>request &middot; manifest])

    %% ─── Stage 1: Pre-commit ───
    subgraph PRECOMMIT [Pre-Commit &mdash; sub-second &middot; developer machine]
        direction TB
        LINT[Linters<br/>shellcheck &middot; ruff<br/>ESLint]
        FORMAT[Formatters<br/>style &middot; whitespace]
        FAST_SCHEMA[Fast Schema<br/>JSON Schema &middot; Pydantic<br/>local checks]
    end

    GATE_PC{Pre-Commit Gate<br/>pass / block commit}

    %% ─── Stage 2: CI ───
    subgraph CI [CI &mdash; minutes &middot; shared infrastructure]
        direction TB
        FULL_SCHEMA[Full Schema Validation<br/>complete coverage]
        CONTRACT[Contract Tests<br/>Pact &middot; Schemathesis<br/>boundary validation]
        SEMANTIC[Semantic Checks<br/>domain rules<br/>integration tests]
        SECURITY[Security Scans<br/>vuln scanning<br/>secret detection]
    end

    GATE_CI{CI Gate<br/>pass / block merge}

    %% ─── Stage 3: Deploy ───
    subgraph DEPLOY [Deploy &mdash; deploy window &middot; staging gates]
        direction TB
        CONFIG_VAL[Config Validators<br/>env-specific values]
        IAC_POLICY[IaC Policy<br/>OPA &middot; Conftest<br/>infrastructure rules]
        DEP_CHECK[Dependency Checks<br/>vuln scan &middot; license]
    end

    GATE_DEPLOY{Deploy Gate<br/>proceed / defer / rollback}

    %% ─── Stage 4: Runtime ───
    subgraph RUNTIME [Runtime &mdash; sub-millisecond &middot; production]
        direction TB
        REQ_VAL[Request Validation<br/>against API contract<br/>JSON Schema runtime]
        RESP_VAL[Response Validation<br/>output schema check]
        RATE[Rate Limit<br/>quotas &middot; throttling]
    end

    GATE_RT{Runtime Gate<br/>accept / reject / throttle}

    %% ─── Outcomes ───
    PROCEED([Input Proceeds])
    REJECTED([Input Rejected<br/>actionable message])

    %% ─── Calibration ───
    OVERRIDE([Override Recorded])
    FALSE_POS{False Positive?}
    REVISION[Validator Revision<br/>versioned &middot; tested]

    %% ─── Flow ───
    INPUT --> PRECOMMIT
    PRECOMMIT --> GATE_PC
    GATE_PC -->|pass| CI
    GATE_PC -->|fail| REJECTED

    CI --> GATE_CI
    GATE_CI -->|pass| DEPLOY
    GATE_CI -->|fail| REJECTED

    DEPLOY --> GATE_DEPLOY
    GATE_DEPLOY -->|pass| RUNTIME
    GATE_DEPLOY -->|fail| REJECTED

    RUNTIME --> GATE_RT
    GATE_RT -->|pass| PROCEED
    GATE_RT -->|fail| REJECTED

    %% Calibration loop
    REJECTED -.-> OVERRIDE
    OVERRIDE --> FALSE_POS
    FALSE_POS -->|yes| REVISION
    REVISION -.updates.-> PRECOMMIT
    REVISION -.updates.-> CI
    REVISION -.updates.-> DEPLOY
    REVISION -.updates.-> RUNTIME

    %% ─── NODE STYLES ───
    style INPUT    fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style PROCEED  fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style REJECTED fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410

    %% Pre-commit (palest)
    style LINT        fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style FORMAT      fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style FAST_SCHEMA fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316

    %% CI (mid amber)
    style FULL_SCHEMA fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style CONTRACT    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style SEMANTIC    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style SECURITY    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Deploy (warm)
    style CONFIG_VAL fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style IAC_POLICY fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style DEP_CHECK  fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410

    %% Runtime (warmest)
    style REQ_VAL  fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style RESP_VAL fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style RATE     fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410

    %% Gates emphasised
    style GATE_PC     fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410
    style GATE_CI     fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410
    style GATE_DEPLOY fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410
    style GATE_RT     fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410

    %% Calibration: cooler tones
    style OVERRIDE  fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style FALSE_POS fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style REVISION  fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.8px,color:#2C4258

    %% ─── CLUSTER STYLES ───
    style PRECOMMIT fill:#FEF8E5,stroke:#D4C599,stroke-width:1.4px,color:#5C4316
    style CI        fill:#FEF3C7,stroke:#D4A87A,stroke-width:1.4px,color:#5C4316
    style DEPLOY    fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
    style RUNTIME   fill:#FBEDE0,stroke:#C96330,stroke-width:1.4px,color:#3A2410
