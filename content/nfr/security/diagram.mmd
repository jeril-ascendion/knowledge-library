requirementDiagram

    requirement DataClassification {
        id: DC-1
        text: Data is classified by sensitivity (public/internal/confidential/restricted)
        risk: high
        verifymethod: inspection
    }

    requirement ThreatModel {
        id: TM-1
        text: Threat model exists per significant subsystem
        risk: high
        verifymethod: inspection
    }

    requirement AuthMFA {
        id: AC-1
        text: MFA enforcement at 100% for confidential-data access
        risk: high
        verifymethod: test
    }

    requirement AuthSession {
        id: AC-2
        text: Session lifetime ceiling enforced per population
        risk: medium
        verifymethod: test
    }

    requirement SecretsRotation {
        id: SM-1
        text: Secrets rotated per scheduled cadence with audit
        risk: high
        verifymethod: test
    }

    requirement AuditTrail {
        id: AT-1
        text: Privileged actions logged immutably with regulatory retention
        risk: high
        verifymethod: inspection
    }

    requirement EncryptionAtRest {
        id: EN-1
        text: Restricted data encrypted at rest with managed keys
        risk: high
        verifymethod: test
    }

    requirement FindingLedger {
        id: FL-1
        text: Security findings tracked with close/accept/revise decisions
        risk: medium
        verifymethod: inspection
    }

    element ApplicationCode {
        type: software
    }

    element AuthenticationService {
        type: service
    }

    element SecretsStore {
        type: platform
    }

    element AuditPipeline {
        type: platform
    }

    element ComplianceProgram {
        type: process
    }

    ThreatModel - traces -> DataClassification
    DataClassification - satisfies -> ApplicationCode
    DataClassification - satisfies -> EncryptionAtRest
    AuthMFA - satisfies -> AuthenticationService
    AuthSession - satisfies -> AuthenticationService
    SecretsRotation - satisfies -> SecretsStore
    AuditTrail - satisfies -> AuditPipeline
    EncryptionAtRest - satisfies -> ApplicationCode
    FindingLedger - traces -> ComplianceProgram
    AuthMFA - traces -> ThreatModel
    SecretsRotation - traces -> ThreatModel
