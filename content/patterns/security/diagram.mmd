flowchart TB

    %% ─── External entities ───
    USER([User])

    %% ─── Identity provider (control plane) ───
    IDP[Identity Provider<br/>OIDC / SAML / Workload Identity]

    %% ─── Edge: API gateway verifies tokens ───
    GATEWAY[API Gateway<br/>verifies identity at perimeter]

    %% ─── Service mesh: every call verifies identity ───
    subgraph TRUST [Zero Trust &mdash; every boundary verifies]
        direction LR
        SVC_A[Service A]
        SVC_B[Service B]
    end

    %% ─── Secret store (separate trust domain) ───
    SECRETS[(Secret Store<br/>HSM / KMS &middot; rotated)]

    %% ─── Encrypted persistence ───
    DB[(Encrypted Datastore<br/>at rest &middot; in transit)]

    %% ─── Tamper-evident audit log (separate trust domain) ───
    AUDIT[(Audit Log<br/>append-only &middot; tamper-evident)]

    %% ─── User authentication ───
    USER --> IDP
    IDP -.signed token.-> USER
    USER --> GATEWAY
    GATEWAY -.verify token.-> IDP

    %% ─── Service-to-service auth ───
    GATEWAY --> SVC_A
    SVC_A -.mTLS / workload id.-> SVC_B
    SVC_A --> SVC_B

    %% ─── Data and secret access ───
    SVC_A --> DB
    SVC_B --> DB
    SVC_A -.fetches keys.-> SECRETS
    SVC_B -.fetches keys.-> SECRETS

    %% ─── Audit propagation ───
    GATEWAY -.events.-> AUDIT
    SVC_A -.events.-> AUDIT
    SVC_B -.events.-> AUDIT
    IDP -.events.-> AUDIT

    %% ─── NODE STYLES ───
    %% Entry: bright blue
    style USER fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Identity provider: emphasised cream (the control plane)
    style IDP fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Gateway: cream (the verification surface)
    style GATEWAY fill:#FBEDE0,stroke:#A07A4A,stroke-width:2px,color:#3A2410

    %% Services: blue (the workloads)
    style SVC_A fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840
    style SVC_B fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840

    %% Storage: amber
    style DB      fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style SECRETS fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316

    %% Audit: distinctive grey (cross-cutting, separate trust domain)
    style AUDIT fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.8px,color:#2C2C2C

    %% ─── CLUSTER STYLE ───
    style TRUST fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
