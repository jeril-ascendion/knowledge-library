flowchart LR

    %% ─── External caller (sync path entry) ───
    USER([External Caller])

    %% ─── Synchronous path: API gateway with OpenAPI contract ───
    GATEWAY[API Gateway<br/>OpenAPI contract]

    %% ─── Producer service ───
    subgraph SVC_X [Service X &mdash; producer]
        direction TB
        XLOGIC[Business Logic]
        XOUTBOX[(Transactional<br/>Outbox)]
    end

    %% ─── Asynchronous backbone with AsyncAPI contract ───
    BUS[Event Stream<br/>AsyncAPI contract]

    %% ─── Idempotent consumers ───
    subgraph CONS [Consumers &mdash; idempotent]
        direction TB
        SVC_B[Service B]
        SVC_C[Service C]
    end

    %% ─── Failure handling ───
    DLQ[(Dead-Letter<br/>Queue)]

    %% ─── Synchronous flow ───
    USER --> GATEWAY
    GATEWAY --> XLOGIC
    XLOGIC --> GATEWAY
    GATEWAY --> USER

    %% ─── Asynchronous flow ───
    XLOGIC --> XOUTBOX
    XOUTBOX --> BUS
    BUS --> SVC_B
    BUS --> SVC_C

    %% ─── Failure paths ───
    SVC_B -.failed messages.-> DLQ
    SVC_C -.failed messages.-> DLQ

    %% ─── NODE STYLES ───
    %% Entry: bright blue
    style USER fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Sync gateway: emphasised cream (the contract surface)
    style GATEWAY fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410

    %% Producer service: blue (logic + outbox)
    style XLOGIC  fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840
    style XOUTBOX fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Async backbone: distinctive amber (the propagation channel)
    style BUS fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Consumers: amber (read side, idempotent)
    style SVC_B fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style SVC_C fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Failure path: distinctive grey
    style DLQ fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C

    %% ─── CLUSTER STYLES ───
    style SVC_X fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
    style CONS  fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
