%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart LR

    %% ─── Source: developer ───
    DEV([Developer])

    %% ─── CI: build immutable artifact ───
    BUILD[Immutable Artifact<br/>built &amp; tested in CI]

    %% ─── Production: two coexisting versions ───
    subgraph PROD [Production Environment]
        direction TB
        OLD[Version N&minus;1<br/>established baseline]
        NEW[Version N<br/>candidate]
    end

    %% ─── Traffic router: weighted split ───
    ROUTE[Traffic Router<br/>5% &rarr; 25% &rarr; 50% &rarr; 100%]

    %% ─── Users at the receiving end ───
    USERS([Users])

    %% ─── Observability: signals from prod ───
    METRICS[Observability<br/>SLOs &middot; error rate &middot; latency]

    %% ─── Decision: advance, hold, or rollback ───
    DECIDE{Promote canary<br/>or roll back?}

    %% ─── Build flow ───
    DEV --> BUILD
    BUILD --> NEW
    BUILD -.keeps warm.-> OLD

    %% ─── Traffic flow ───
    OLD --> ROUTE
    NEW --> ROUTE
    ROUTE --> USERS

    %% ─── Feedback loop ───
    USERS -.signals.-> METRICS
    METRICS --> DECIDE
    DECIDE -.shift weights.-> ROUTE

    %% ─── NODE STYLES ───
    %% Entry / exit (humans)
    style DEV   fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style USERS fill:#1ABC9C,stroke:#138D75,stroke-width:2px,color:#FFFFFF

    %% Build artifact: cream (the immutable handoff)
    style BUILD fill:#FBEDE0,stroke:#A07A4A,stroke-width:1.8px,color:#3A2410

    %% Production versions: contrasting blue/amber to show coexistence
    style OLD fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840
    style NEW fill:#FEF3C7,stroke:#C96330,stroke-width:2.2px,color:#5C4316

    %% Traffic router: emphasis (the control point)
    style ROUTE fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Observability: cross-cutting grey
    style METRICS fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C

    %% Decision: diamond (already shaped by syntax), styled with emphasis
    style DECIDE fill:#FEF3C7,stroke:#92722C,stroke-width:2px,color:#5C4316

    %% ─── CLUSTER STYLE ───
    style PROD fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
