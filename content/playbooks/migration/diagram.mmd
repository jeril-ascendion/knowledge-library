flowchart TB

    %% ─── Migration trigger ───
    START([Migration Required<br/>legacy system &rarr; new architecture])

    %% ─── Decision diamonds ───
    Q1{Sliceable into<br/>independently<br/>migratable pieces?}
    Q2{Tightly coupled<br/>at code level?}
    Q3{Stateless or<br/>solved state sync?}
    Q4{Behavioural<br/>equivalence verifiable<br/>empirically?}
    Q5{Parallel cost prohibitive<br/>AND full pre-cutover<br/>validation possible?}

    %% ─── Strategy outcomes (one node per strategy, 3-line description) ───
    S1[Strangler Fig<br/>incremental replacement<br/>behind a routing layer]
    S2[Branch by Abstraction<br/>code-level interface;<br/>switch the binding]
    S3[Blue-Green<br/>parallel deploy;<br/>traffic switch at gateway]
    S4[Parallel Run<br/>both systems same input;<br/>compare outputs]
    S5[Big-Bang Cutover<br/>last resort; high risk;<br/>tested rollback required]
    RECON[Reconsider scope<br/>or invest in slicing first]

    %% ─── Universal discipline ───
    DISC[Discipline applied to all paths<br/>characterisation tests &middot; data migration<br/>rollback rehearsal &middot; decommissioning]

    %% ─── Outcome ───
    DONE([Migration Complete<br/>legacy actually removed])

    %% ─── Decision flow ───
    START --> Q1
    Q1 -->|yes| S1
    Q1 -->|no| Q2
    Q2 -->|yes| S2
    Q2 -->|no| Q3
    Q3 -->|yes| S3
    Q3 -->|no| Q4
    Q4 -->|yes| S4
    Q4 -->|no| Q5
    Q5 -->|yes| S5
    Q5 -->|no| RECON

    %% ─── All strategy paths converge through discipline to completion ───
    S1 --> DISC
    S2 --> DISC
    S3 --> DISC
    S4 --> DISC
    S5 --> DISC

    DISC --> DONE

    %% ─── Node styles ───
    style START fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style DONE  fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style RECON fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410

    %% Decision diamonds — terracotta accent for prominence
    style Q1 fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style Q2 fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style Q3 fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style Q4 fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style Q5 fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410

    %% Strategy outcomes — distinct fill per strategy for visual differentiation
    style S1 fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style S2 fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style S3 fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style S4 fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style S5 fill:#F4E5DD,stroke:#A37050,stroke-width:1.5px,color:#3A2410

    %% Universal discipline — emphasised
