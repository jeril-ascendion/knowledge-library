flowchart LR

    %% ─── Six lifecycle phases as horizontal sequence ───
    A["Drafted<br/>pre-release design review<br/>against documented conventions"]
    B["Beta<br/>private alpha or controlled beta<br/>breaking changes expected"]
    C["GA<br/>public release<br/>full support; recommended version"]
    D["Maintenance<br/>security and high-severity<br/>bug fixes only"]
    E["Deprecated<br/>Sunset announced<br/>migration tooling published"]
    F["Retired<br/>410 Gone responses<br/>code and infrastructure removed"]

    A --> B
    B --> C
    C --> D
    D --> E
    E --> F

    %% ─── Three discipline annotations attached to the relevant phases ───
    COEX["<b>Multi-version coexistence</b><br/>when this version enters Maintenance,<br/>the next major version (vN+1) enters its own GA;<br/>both versions live in production simultaneously,<br/>bounded by the announced sunset date"]

    DISC["<b>Deprecation discipline</b><br/>Sunset HTTP header on every response;<br/>reminder cadence at T-12, T-6, T-3, T-1 months;<br/>identified consumers receive direct outreach;<br/>migration tooling published with announcement"]

    EXEC["<b>Retirement executes</b><br/>sunset date is binding (no rolling extensions);<br/>routes return 410 Gone with migration docs;<br/>code deleted from source repo after grace period;<br/>infrastructure destroyed last"]

    D -.-> COEX
    E -.-> DISC
    F -.-> EXEC

    %% ─── Phase styles: progression from neutral through terracotta ───
    style A fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style B fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style C fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style D fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style E fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style F fill:#F4E5DD,stroke:#A37050,stroke-width:1.5px,color:#3A2410

    %% ─── Annotation styles: subtle backgrounds matching their attached phase ───
    style COEX fill:#FEF8E5,stroke:#D4C599,stroke-width:1px,color:#5C4316
    style DISC fill:#FBEDE0,stroke:#D4C599,stroke-width:1px,color:#3A2410
    style EXEC fill:#F4E5DD,stroke:#D4C599,stroke-width:1px,color:#3A2410
