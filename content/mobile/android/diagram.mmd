flowchart TD
    subgraph UI["UI Layer (Compose)"]
        A1[Composable Screen]
        A2[StateFlow&lt;UiState&gt;]
        A3[sealed UiState: Loading/Content/Error]
    end

    subgraph VM["Presentation Layer"]
        B1[ViewModel @HiltViewModel]
        B2[viewModelScope coroutines]
    end

    subgraph DOMAIN["Domain Layer"]
        C1[Use Cases]
        C2[Domain Models]
    end

    subgraph DATA["Data Layer"]
        D1[Repository]
        D2[Remote — Retrofit + Kotlinx Serialization]
        D3[Local — Room Database]
        D4[EncryptedSharedPreferences + Keystore]
    end

    subgraph PLATFORM["Platform"]
        E1[Hilt DI Graph]
        E2[Baseline Profile / Macrobenchmark]
        E3[R8 + ProGuard]
    end

    A1 --> A2
    A2 --> A3
    A1 -.collectAsStateWithLifecycle.-> B1
    B1 --> B2
    B2 --> C1
    C1 --> C2
    C1 --> D1
    D1 --> D2
    D1 --> D3
    D1 --> D4

    E1 -.injects.-> B1
    E1 -.injects.-> D1
    E2 -.optimises.-> A1
    E3 -.shrinks.-> UI

    style A1 fill:#C96330,color:#fff
    style B1 fill:#DCEAFC,stroke:#3D6395,stroke-width:2px
    style D1 fill:#DCEAFC,stroke:#3D6395,stroke-width:2px
    style D4 fill:#FBEDE0,stroke:#C96330,stroke-width:2px
