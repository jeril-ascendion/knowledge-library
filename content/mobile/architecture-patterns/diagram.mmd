flowchart LR
    subgraph VIEW["View Layer"]
        V1[Composable / SwiftUI View]
        V2[Observes State]
        V3[Emits Events / Intents]
    end

    subgraph PRESENTATION["Presentation Layer"]
        P1[ViewModel / Store / Reducer]
        P2[Holds StateFlow / @Observable]
        P3[Processes Events → New State]
    end

    subgraph DOMAIN["Domain Layer"]
        D1[Use Case]
        D2[Domain Entity]
        D3[Repository Interface]
    end

    subgraph DATA["Data Layer"]
        DA1[Repository Implementation]
        DA2[Remote DataSource]
        DA3[Local DataSource]
    end

    V1 --> V2
    V1 --> V3
    V2 -.reads.-> P2
    V3 -.dispatches.-> P3
    P1 --> P3
    P3 --> D1
    D1 --> D2
    D1 --> D3
    D3 -.implemented by.-> DA1
    DA1 --> DA2
    DA1 --> DA3
    DA2 -.maps DTO to.-> D2
    DA3 -.maps Entity to.-> D2

    style V1 fill:#C96330,color:#fff
    style P1 fill:#DCEAFC,stroke:#3D6395,stroke-width:2px
    style D1 fill:#DCEAFC,stroke:#3D6395,stroke-width:2px
    style DA1 fill:#FBEDE0,stroke:#C96330,stroke-width:2px
