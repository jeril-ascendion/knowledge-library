%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
classDiagram
    direction TB

    class Review {
        +ScopeStatement scope
        +List~Finding~ findings
        +List~Dialogue~ discussions
        +Decision decision
        +List~OutcomeLink~ outcomes
        +DateTime conducted_at
        +String reviewer_identity
    }

    class ScopeStatement {
        +String artefact_under_review
        +String version_or_reference
        +List~String~ criteria_evaluated
        +String review_depth
        +List~String~ explicitly_out_of_scope
    }

    class Finding {
        +Severity severity
        +String issue_description
        +Location location
        +String recommendation
        +ResolutionStatus resolution
    }

    class Severity {
        <<enumeration>>
        BLOCKER
        SIGNIFICANT
        MINOR
        OBSERVATION
    }

    class Location {
        +String document_section
        +String code_file
        +Integer line_number
        +String component_name
        +String configuration_key
    }

    class Dialogue {
        +String finding_reference
        +String author_response
        +String reviewer_followup
        +String resolution_reached
        +Boolean dissent_preserved
    }

    class Decision {
        +DecisionOutcome outcome
        +String decision_authority
        +String rationale
        +List~String~ required_changes
    }

    class DecisionOutcome {
        <<enumeration>>
        PROCEED
        PROCEED_WITH_CHANGES
        DEFER
        REJECT
    }

    class ResolutionStatus {
        <<enumeration>>
        FIXED
        DEFERRED
        ACCEPTED_AS_IS
        OPEN
    }

    class OutcomeLink {
        +String finding_reference
        +ResolutionStatus status
        +String pr_url
        +String ticket_url
        +String rationale_if_accepted_as_is
    }

    Review       *-- "1"    ScopeStatement  : has
    Review       *-- "1..*" Finding         : contains
    Review       *-- "0..*" Dialogue        : captures
    Review       *-- "1"    Decision        : concludes_with
    Review       *-- "0..*" OutcomeLink     : tracks

    Finding      *-- "1"    Location        : references
    Finding      ..>        Severity        : classified_by
    Finding      ..>        ResolutionStatus : tracked_by

    Decision     ..>        DecisionOutcome : selects

    OutcomeLink  ..>        ResolutionStatus : reports
    OutcomeLink  ..>        Finding         : closes_loop_on

    note for Review "Composition root: the document is a structured artefact whose fields determine review survival."
    note for Severity "Documented vocabulary at the organisation level; reviewers calibrate against the same scale."
    note for OutcomeLink "Closes the loop: every finding resolves to fixed, deferred, or accepted-as-is with rationale."
