%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart TB

    %% ─── Service input ───
    SVC([Service Under Assessment])

    %% ─── Dimensions cluster ───
    subgraph DIM [Six Dimensions Rated]
        direction TB
        D_PR[Production Readiness]
        D_OBS[Observability]
        D_SEC[Security]
        D_REL[Reliability]
        D_PERF[Performance]
        D_COST[Cost Efficiency]
    end

    %% ─── Scoring cluster ───
    subgraph SCORING [Scoring Workflow &mdash; per dimension, owner-driven with peer review]
        direction TB
        CRIT[Documented Criteria<br/>per level &middot; verifiable language]
        EVIDENCE[Evidence Gathering<br/>dashboards &middot; threat models<br/>runbooks &middot; metrics]
        OWNER_RATE[Owner Rating<br/>L1 / L2 / L3 / L4<br/>backed by evidence]
        PEER[Peer Review<br/>architect &middot; platform team<br/>cross-team owner]
        DISAGREE{Rating<br/>Agreed?}
        FINAL[Final Level Assignment<br/>recorded with evidence + reviewer]

        CRIT --> EVIDENCE
        EVIDENCE --> OWNER_RATE
        OWNER_RATE --> PEER
        PEER --> DISAGREE
        DISAGREE -->|yes| FINAL
        DISAGREE -->|no| EVIDENCE
    end

    %% ─── Aggregation cluster ───
    subgraph AGG [Aggregation &mdash; portfolio view, no composite collapse]
        direction TB
        SC_THIS[Per-Service Scorecard<br/>this cycle &middot; versioned]
        MATRIX[Portfolio Matrix<br/>services &times; dimensions &times; levels]
        TRAJ[Trajectory View<br/>per-service per-dimension<br/>movement over cycles]
        PATTERNS[Pattern Aggregations<br/>median per dimension &middot; distribution<br/>at each level &middot; cohort movement]

        SC_THIS --> MATRIX
        MATRIX --> TRAJ
        MATRIX --> PATTERNS
    end

    %% ─── Calibration cluster ───
    subgraph CAL [Calibration &mdash; criteria revised against operational outcomes]
        direction TB
        OPS_DATA[Operational Data<br/>incidents &middot; MTTR &middot; CFR<br/>customer-facing reliability]
        DIVERGE{Ratings<br/>predict<br/>outcomes?}
        REVISE[Criteria Revision<br/>versioned &middot; reason recorded]

        OPS_DATA --> DIVERGE
        DIVERGE -->|no &mdash; criteria miss| REVISE
    end

    %% ─── Outcome ───
    DECISIONS([Investment Decisions<br/>platform / per-team support<br/>focused interventions])

    %% ─── Cross-cluster edges (specific nodes only — never subgraph names) ───
    SVC --> D_PR & D_OBS & D_SEC & D_REL & D_PERF & D_COST
    D_PR & D_OBS & D_SEC & D_REL & D_PERF & D_COST --> CRIT

    FINAL    --> SC_THIS

    TRAJ     --> DECISIONS
    PATTERNS --> DECISIONS

    %% ─── Calibration loop edges ───
    SC_THIS  -.tracked against.->        OPS_DATA
    DIVERGE  -.yes &mdash; criteria hold.-> MATRIX
    REVISE   -.updates.->                CRIT
    DISAGREE -.recurring disagreements.-> REVISE

    %% ─── Node styles ───
    style SVC       fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style DECISIONS fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Dimensions (palest tier — what gets rated)
    style D_PR    fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style D_OBS   fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style D_SEC   fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style D_REL   fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style D_PERF  fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style D_COST  fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316

    %% Scoring (mid amber — process)
    style CRIT       fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style EVIDENCE   fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style OWNER_RATE fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style PEER       fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style DISAGREE   fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style FINAL      fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316

    %% Aggregation (warm — output)
    style SC_THIS  fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style MATRIX   fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style TRAJ     fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style PATTERNS fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410

    %% Calibration (cooler tones — feedback)
    style OPS_DATA fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style DIVERGE  fill:#E5ECF3,stroke:#5A7A9A,stroke-width:2px,color:#2C4258
    style REVISE   fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.8px,color:#2C4258

    %% ─── Cluster styles ───
    style DIM     fill:#FEF8E5,stroke:#D4C599,stroke-width:1.4px,color:#5C4316
    style SCORING fill:#FEF3C7,stroke:#D4A87A,stroke-width:1.4px,color:#5C4316
    style AGG     fill:#FBEDE0,stroke:#C96330,stroke-width:1.4px,color:#3A2410
    style CAL     fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.4px,color:#2C4258
