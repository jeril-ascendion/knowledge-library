flowchart TD

    %% ─── The five stages of the strategy cycle ───
    INTENT["<b>1. Strategic Intent</b><br/>diagnosis &middot; guiding policy &middot; coherent action<br/>articulated by leadership;<br/>kernel articulable from memory"]

    OPTIONS["<b>2. Strategic Options Surfaced</b><br/>alternatives documented;<br/>trade-offs explicit;<br/>chosen path with rationale;<br/>rejected paths preserved"]

    DECISIONS["<b>3. Architectural Decisions</b><br/>ADRs reference strategic premise;<br/>standards justified by intent;<br/>decisions traceable to strategy"]

    EXECUTION["<b>4. Engineering Execution</b><br/>roadmap aligned to decisions;<br/>'why are we doing this' answerable;<br/>discipline at execution level"]

    MEASURE["<b>5. Outcome Measurement</b><br/>predicted outcomes per premise;<br/>cadence matched to time-to-effect;<br/>discrepancy triggers investigation"]

    REVISE["<b>6. Strategic Revision</b><br/>premise correctness investigated;<br/>supersession ADR documents change;<br/>old premise linked forward to new"]

    %% ─── Forward flow: strategy descends from intent through to measurement ───
    INTENT --> OPTIONS
    OPTIONS --> DECISIONS
    DECISIONS --> EXECUTION
    EXECUTION --> MEASURE
    MEASURE --> REVISE

    %% ─── Feedback flow: revision returns to intent for the next cycle ───
    REVISE --> INTENT

    %% ─── Side artefacts that anchor the cycle ───
    KERNEL["<b>Strategy Kernel</b><br/>(Rumelt)<br/>diagnosis &middot; policy &middot; action"]

    OPTIONS_VIS["<b>Wardley Map</b><br/>or equivalent visualisation<br/>options on strategic axes"]

    ADR["<b>ADR Discipline</b><br/>(Nygard)<br/>decision &middot; context &middot;<br/>alternatives &middot; consequences"]

    METRICS["<b>Outcome Metrics</b><br/>(per-premise, not generic)<br/>quantified at strategy time;<br/>before retrospective bias"]

    %% ─── Anchor side-artefacts to their stage ───
    KERNEL -.anchors.-> INTENT
    OPTIONS_VIS -.anchors.-> OPTIONS
    ADR -.anchors.-> DECISIONS
    METRICS -.anchors.-> MEASURE

    %% ─── Style: cycle stages in warm progression ───
    style INTENT    fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410
    style OPTIONS   fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style DECISIONS fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style EXECUTION fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style MEASURE   fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style REVISE    fill:#F4E5DD,stroke:#A37050,stroke-width:1.5px,color:#3A2410

    %% ─── Side artefacts: cooler tones to distinguish from cycle stages ───
    style KERNEL      fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1px,color:#2C4258
    style OPTIONS_VIS fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1px,color:#2C4258
    style ADR         fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1px,color:#2C4258
    style METRICS     fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1px,color:#2C4258
