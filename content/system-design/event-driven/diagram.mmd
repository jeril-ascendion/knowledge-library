flowchart LR

    %% ─── Producers (don't know consumers) ───
    subgraph PRODS [Producers &mdash; emit immutable facts]
        direction TB
        SVC_A[Service A]
        SVC_B[Service B]
        SVC_C[Service C]
    end

    %% ─── Event log (source of truth) ───
    LOG[(Event Log<br/>append-only &middot; partitioned &middot; durable)]

    %% ─── Consumers (don't know each other) ───
    subgraph CONS [Consumers &mdash; independent, idempotent]
        direction TB
        PROJ[Projection<br/>read model]
        SEARCH[Search Indexer]
        ANALYTICS[Analytics<br/>stream processor]
        ALERTS[Alerting<br/>watcher]
    end

    %% ─── Replay (capability, not emergency) ───
    REPLAY[/Replay Tool<br/>any offset<br/>any consumer/]

    %% ─── Producer flow ───
    SVC_A -.OrderPlaced.-> LOG
    SVC_B -.PaymentReceived.-> LOG
    SVC_C -.InventoryReserved.-> LOG

    %% ─── Consumer flow ───
    LOG --> PROJ
    LOG --> SEARCH
    LOG --> ANALYTICS
    LOG --> ALERTS

    %% ─── Replay path ───
    REPLAY -.starts at offset.-> LOG

    %% ─── NODE STYLES ───
    %% Producers: blue (the source of facts)
    style SVC_A fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style SVC_B fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style SVC_C fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Event log: emphasised cream (the source of truth)
    style LOG fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Consumers: amber (derived views)
    style PROJ      fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style SEARCH    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style ANALYTICS fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style ALERTS    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Replay: distinctive grey (operator capability)
    style REPLAY fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C

    %% ─── CLUSTER STYLES ───
    style PRODS fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
    style CONS  fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
