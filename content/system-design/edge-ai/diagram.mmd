flowchart LR

    %% ─── Edge devices (where data and inference live) ───
    subgraph EDGE [Edge &mdash; devices, local inference]
        direction TB
        DEV1[Device A<br/>compressed model]
        DEV2[Device B<br/>compressed model]
        DEV3[Device C<br/>compressed model]
    end

    %% ─── Sync channel (carrying minimum necessary upstream) ───
    SYNC[Sync Channel<br/>telemetry &middot; anomalies &middot; gradients]

    %% ─── Cloud side (training and orchestration) ───
    subgraph CLOUD [Cloud &mdash; training, orchestration, OTA]
        direction TB
        AGG[Aggregator<br/>federated training &middot; drift detection]
        TRAIN[Training Pipeline<br/>next-gen model]
        OTA[OTA Distribution<br/>staged rollout]
    end

    %% ─── User-facing data (stays at edge) ───
    DATA([User Data<br/>stays on device])

    %% ─── Local inference flow ───
    DATA --> DEV1
    DATA --> DEV2
    DATA --> DEV3

    %% ─── Upstream: minimum necessary ───
    DEV1 -.telemetry.-> SYNC
    DEV2 -.telemetry.-> SYNC
    DEV3 -.telemetry.-> SYNC
    SYNC --> AGG

    %% ─── Cloud-side processing ───
    AGG --> TRAIN
    TRAIN --> OTA

    %% ─── Downstream: model updates ───
    OTA -.compressed model.-> DEV1
    OTA -.compressed model.-> DEV2
    OTA -.compressed model.-> DEV3

    %% ─── NODE STYLES ───
    style DATA fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Edge devices: emphasised blue (the inference site)
    style DEV1 fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2.2px,color:#1A2840
    style DEV2 fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2.2px,color:#1A2840
    style DEV3 fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2.2px,color:#1A2840

    %% Sync channel: cream (the constrained pipe)
    style SYNC fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410

    %% Cloud-side: amber (training and orchestration)
    style AGG   fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style TRAIN fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style OTA   fill:#FEF3C7,stroke:#C96330,stroke-width:2px,color:#5C4316

    %% ─── CLUSTER STYLES ───
    style EDGE  fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
    style CLOUD fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
