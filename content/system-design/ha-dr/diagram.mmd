flowchart LR

    %% ─── Users / traffic ───
    USERS([Users / traffic])

    %% ─── Routing layer ───
    DNS[DNS / Global LB<br/>health-aware routing]

    %% ─── Primary region (HA within) ───
    subgraph PRIMARY [Primary Region &mdash; HA: multi-AZ, automatic failover]
        direction TB
        LB1[Regional LB<br/>health checks]
        APP1[App tier<br/>multi-AZ]
        DB_PRI[(Primary DB<br/>quorum write)]
        APP1 --> DB_PRI
        LB1 --> APP1
    end

    %% ─── Secondary region (DR target) ───
    subgraph SECONDARY [Secondary Region &mdash; DR: async replicated, runbook failover]
        direction TB
        LB2[Regional LB<br/>warm standby]
        APP2[App tier<br/>warm standby]
        DB_SEC[(DR Replica<br/>async, RPO bounded)]
        APP2 --> DB_SEC
        LB2 --> APP2
    end

    %% ─── Immutable backups (separate from replication) ───
    BACKUP[(Immutable Backup<br/>cross-region, retention enforced)]

    %% ─── Runbook layer ───
    RUNBOOK[/Runbooks &middot; Game Days<br/>rehearsed recovery/]

    %% ─── Traffic flow ───
    USERS --> DNS
    DNS --> LB1
    DNS -.DR cutover.-> LB2

    %% ─── Replication ───
    DB_PRI -.async replication<br/>RPO &lt; 5min.-> DB_SEC

    %% ─── Backup ───
    DB_PRI --> BACKUP
    BACKUP -.restore on disaster.-> DB_SEC

    %% ─── Runbook drives DR ───
    RUNBOOK -.triggers / verifies.-> DNS
    RUNBOOK -.triggers / verifies.-> LB2

    %% ─── NODE STYLES ───
    style USERS fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style DNS   fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410

    %% Primary: emphasised blue (active production)
    style LB1    fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style APP1   fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style DB_PRI fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2.2px,color:#1A2840

    %% Secondary: cooler grey-blue (warm but inactive)
    style LB2    fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style APP2   fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style DB_SEC fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.8px,color:#2C4258

    %% Backup: amber (durable archive)
    style BACKUP fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316

    %% Runbook: distinct grey (operator capability)
    style RUNBOOK fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C

    %% ─── CLUSTER STYLES ───
    style PRIMARY   fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.4px,color:#1A2840
    style SECONDARY fill:#F2F4F7,stroke:#9CB0C4,stroke-width:1.2px,color:#2C4258
