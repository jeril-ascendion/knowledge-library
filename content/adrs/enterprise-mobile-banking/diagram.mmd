flowchart TD

    subgraph DEVICE["📱 Trusted Device — Application Trust Zone"]
        direction TB
        subgraph PRESENT["Presentation Layer — Compose / SwiftUI"]
            VIEW["View / Composable\nUser Events · State Rendering\nNo Business Logic"]
            VM["ViewModel\nUiState: StateFlow / @Observable\nLifecycle-Aware · No platform imports in domain"]
        end
        subgraph DOMAIN["Domain Layer — Pure Kotlin / Swift · Zero Platform Imports"]
            UC["Use Cases\nOne per Business Operation\nReturns Result of T or DomainError"]
            RI["Repository Interfaces\nDomain Contracts Only\nNo Implementations"]
            DM["Domain Models\ndata class / struct\nBigDecimal for monetary values"]
        end
        subgraph DATA["Data Layer — Interface Adapters"]
            RIMPL["Repository Implementations\nCoordinates Remote + Local"]
            NET["Network DataSource\nRetrofit / URLSession\nOkHttp + CertificatePinner"]
            LOCAL["Local DataSource\nRoom / SwiftData\nSQLCipher Encrypted"]
            CRED["Secure Credential Storage\nAndroid Keystore\niOS Keychain · SecureEnclave"]
        end
        subgraph SEC_DEVICE["🛡 Runtime Security Controls"]
            ATT["Device Attestation\nPlay Integrity API\nApple AppAttest"]
            BIO["Biometric MFA\nBiometricPrompt BIOMETRIC_STRONG\nLocalAuthentication iOS"]
            PIN_CERT["SPKI Certificate Pinning\nTLS 1.3 Mandatory\nCleartext Blocked"]
        end
    end

    subgraph AUTH_PLANE["🔑 Authentication Plane — OAuth 2.0 + PKCE"]
        IDP["Identity Provider\nOkta · Azure AD · OIDC\nAuthorization Server"]
        PKCE_FLOW["PKCE Flow\ncode_verifier on-device\nNo client_secret in binary"]
        TOKEN["Token Architecture\nAccess Token 15min — memory only\nRefresh Token 8hr — Keystore/Keychain"]
    end

    subgraph BFF_PLANE["⚡ Mobile BFF Layer — Mandatory · No Shared Web API"]
        GW["API Gateway\nMobile Auth Enforcement\nRate Limiting · Field Selection"]
        AGG["Aggregation Layer\nCompose Microservice Responses\nDelta Sync · since= parameter"]
        CACHE_BFF["Response Cache\nETag / If-None-Match\nBrotli Compression"]
    end

    subgraph BACKEND["🏗 Backend Microservices"]
        SVC1["Account Service"]
        SVC2["Transaction Service"]
        SVC3["Payment Service"]
        SVC4["Notification Service\nAPNs / FCM\nPayload: notification_id only"]
    end

    subgraph CICD_PLANE["⚙ CI/CD Pipeline — Fastlane + GitHub Actions"]
        PR_GATE["PR Gate\nLint · Unit Tests 90%\nSAST · CVE Scan · Snapshot Diff"]
        BUILD["Parallel Build Matrix\nAndroid ubuntu-latest\niOS macos-latest"]
        SIGN["Code Signing\nfastlane Match iOS\nKeystore Base64 Secret Android"]
        DIST["Distribute\nFirebase App Distribution\nTestFlight Internal"]
        QA_GATE["QA Gate\nGitHub Environment Protection\nQA Lead Approval Required"]
        ROLLOUT["Staged Rollout\n1%→5%→25%→50%→100%\nHealth Gates Between Stages"]
    end

    VIEW -->|"User Events"| VM
    VM -->|"UiState sealed class"| VIEW
    VM --> UC
    UC --> RI
    RI --> RIMPL
    RIMPL --> NET & LOCAL
    RIMPL --> CRED
    NET -->|"TLS 1.3 + SPKI Pinning"| GW
    GW --> AGG
    AGG --> CACHE_BFF
    AGG --> SVC1 & SVC2 & SVC3
    SVC4 -->|"Silent push · notification_id only"| DEVICE
    IDP --> PKCE_FLOW --> TOKEN --> NET
    ATT -.->|"Integrity verdict on every transaction"| DEVICE
    BIO -.->|"Step-up auth for high-risk ops"| AUTH_PLANE
    PIN_CERT -.->|"Enforced on all connections"| NET
    PR_GATE --> BUILD --> SIGN --> DIST --> QA_GATE --> ROLLOUT

