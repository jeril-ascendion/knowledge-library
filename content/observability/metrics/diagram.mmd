flowchart TB

    %% ─── Instrumentation layer ───
    subgraph INSTRUMENT [Instrumentation]
        direction TB
        SERVICE[Service Code]
        RED[RED Metrics<br/>rate &middot; errors &middot; duration]
        USE[USE Metrics<br/>utilization &middot; saturation &middot; errors]
        DOMAIN[Domain Metrics<br/>orders/sec &middot; fraud signals]
        CARD{Cardinality<br/>Validator}
    end

    %% ─── Collection ───
    subgraph COLLECT [Collection Layer]
        direction TB
        PULL[Pull / Scrape<br/>service discovery<br/>Prometheus model]
        PUSH[Push / Agent<br/>StatsD / OTel]
    end

    %% ─── Resolution tiers ───
    subgraph TIERS [Resolution Tiers]
        direction TB
        HIRES[(High-Fidelity<br/>5-15s &middot; 24h-7d)]
        DOWNSAMPLED[(Downsampled<br/>1min &middot; 7-30d)]
        AGGREGATED[(Aggregated<br/>5min-hourly &middot; 30-365d)]
    end

    %% ─── Pre-aggregation pipeline ───
    PREAGG[Pre-Aggregation<br/>per metric-type<br/>functions]

    %% ─── Query + visualization ───
    QUERY[Query Layer<br/>tier-aware]
    DASH[Dashboards<br/>+ Alerting]

    %% ─── Correlation primitives ───
    EXEMPLARS[(Trace Exemplars<br/>linked sample IDs)]
    LOGS_SYS[(Logs System)]
    TRACES_SYS[(Traces System)]

    %% ─── Flow ───
    SERVICE --> RED
    SERVICE --> USE
    SERVICE --> DOMAIN
    RED --> CARD
    USE --> CARD
    DOMAIN --> CARD
    CARD --> COLLECT
    PULL --> HIRES
    PUSH --> HIRES
    HIRES -.downsample.-> PREAGG
    PREAGG --> DOWNSAMPLED
    DOWNSAMPLED -.downsample.-> AGGREGATED

    HIRES --> QUERY
    DOWNSAMPLED --> QUERY
    AGGREGATED --> QUERY
    QUERY --> DASH

    %% ─── Correlation ───
    HIRES -.exemplar.-> EXEMPLARS
    EXEMPLARS -.links to.-> TRACES_SYS
    DASH -.click-through.-> LOGS_SYS
    DASH -.click-through.-> TRACES_SYS

    %% ─── NODE STYLES ───
    style SERVICE fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Canonical metric methods: emphasised cream
    style RED fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style USE fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style DOMAIN fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Cardinality gate: emphasised
    style CARD fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Collection: amber (the routing layer)
    style PULL fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style PUSH fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Tiers: gradient from emphasised (recent) to subtle (old)
    style HIRES       fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style DOWNSAMPLED fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style AGGREGATED  fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316

    style PREAGG fill:#F4E5DD,stroke:#A37050,stroke-width:1.5px,color:#3A2410

    %% Query / dashboards: blue
    style QUERY fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style DASH  fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840

    %% Correlation: cooler tone
    style EXEMPLARS  fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.6px,color:#2C4258
    style LOGS_SYS   fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C
    style TRACES_SYS fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C

    %% ─── CLUSTER STYLES ───
    style INSTRUMENT fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
    style COLLECT    fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
    style TIERS      fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
