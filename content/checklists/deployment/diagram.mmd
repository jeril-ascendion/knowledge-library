%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart TB

    %% ─── Change ready ───
    CHANGE([Change Ready for Deploy])

    %% ─── Stage 1: Pre-deploy ───
    subgraph PREDEPLOY [Stage 1: Pre-Deploy &mdash; verify preconditions]
        direction TB
        ROLLBACK_EXERCISED[Rollback Exercised<br/>date &middot; timing]
        MONITORING[Monitoring Exists<br/>new behaviour + failure modes]
        RUNBOOKS[Runbooks Exist<br/>for new failure modes]
        TEAMS_NOTIFIED[Dependent Teams<br/>notified]
        CAPACITY_VAL[Capacity Validated<br/>for new load profile]
    end

    GATE1{Pre-Deploy Gate<br/>proceed / defer}

    %% ─── Stage 2: Deploy-time ───
    subgraph DEPLOYTIME [Stage 2: Deploy-Time &mdash; in-flight thresholds]
        direction TB
        ERR_RATE[Error Rate<br/>threshold X &middot; window Y]
        LATENCY[P99 Latency<br/>threshold Y &middot; window]
        BIZ_METRIC[Key Business Metric<br/>orders/sec &middot; signups/sec]
    end

    GATE2{Deploy-Time Gate<br/>continue / pause / rollback}

    %% ─── Stage 3: Post-deploy ───
    subgraph POSTDEPLOY [Stage 3: Post-Deploy &mdash; soak + outcome]
        direction TB
        SOAK[Soak Period<br/>30 min to several hours<br/>continued vigilance]
        OUTCOME[Outcome Verification<br/>change does what intended<br/>specific signals]
    end

    GATE3{Post-Deploy Gate<br/>complete / rollback}

    %% ─── Outcomes ───
    SHIPPED([Deploy Complete])
    DEFERRED([Defer Until Addressed])
    ROLLED_BACK([Rolled Back])

    %% ─── Calibration loop ───
    INCIDENT([Deploy-Related Incident])
    POSTMORTEM['Would checklist<br/>have caught this?']
    REVISION[Revision Queue<br/>versioned &middot; reviewed]

    %% ─── CI/CD integration ───
    PIPELINE[(CI/CD Pipeline<br/>deploy ticket &middot; change request<br/>tooling integration)]

    %% ─── Flow ───
    CHANGE --> PREDEPLOY
    PREDEPLOY --> GATE1
    GATE1 -->|pass| DEPLOYTIME
    GATE1 -->|fail| DEFERRED

    DEPLOYTIME --> GATE2
    GATE2 -->|continue| POSTDEPLOY
    GATE2 -->|pause| GATE2
    GATE2 -->|rollback| ROLLED_BACK

    POSTDEPLOY --> GATE3
    GATE3 -->|outcome verified| SHIPPED
    GATE3 -->|breach during soak| ROLLED_BACK

    %% Pipeline surfaces checklist at each stage
    PIPELINE -.surfaces.-> PREDEPLOY
    PIPELINE -.surfaces.-> DEPLOYTIME
    PIPELINE -.surfaces.-> POSTDEPLOY

    %% Calibration
    ROLLED_BACK --> INCIDENT
    SHIPPED -.related issue.-> INCIDENT
    INCIDENT --> POSTMORTEM
    POSTMORTEM --> REVISION
    REVISION -.updates.-> PREDEPLOY
    REVISION -.updates.-> DEPLOYTIME
    REVISION -.updates.-> POSTDEPLOY

    %% ─── NODE STYLES ───
    style CHANGE       fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style SHIPPED      fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style DEFERRED     fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410
    style ROLLED_BACK  fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410

    %% Stage 1 items
    style ROLLBACK_EXERCISED fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style MONITORING         fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style RUNBOOKS           fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style TEAMS_NOTIFIED     fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316
    style CAPACITY_VAL       fill:#FEF8E5,stroke:#A8956A,stroke-width:1.5px,color:#5C4316

    %% Stage 2 items
    style ERR_RATE   fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style LATENCY    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style BIZ_METRIC fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Stage 3 items
    style SOAK    fill:#FBEDE0,stroke:#C96330,stroke-width:1.6px,color:#3A2410
    style OUTCOME fill:#FBEDE0,stroke:#C96330,stroke-width:1.6px,color:#3A2410

    %% Gates: emphasised (the architectural decision points)
    style GATE1 fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410
    style GATE2 fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410
    style GATE3 fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Calibration: cooler tone
    style INCIDENT   fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410
    style POSTMORTEM fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style REVISION   fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.8px,color:#2C4258

    %% Pipeline: blue
    style PIPELINE fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% ─── CLUSTER STYLES ───
    style PREDEPLOY  fill:#FEF8E5,stroke:#D4C599,stroke-width:1.4px,color:#5C4316
    style DEPLOYTIME fill:#FEF3C7,stroke:#D4A87A,stroke-width:1.4px,color:#5C4316
    style POSTDEPLOY fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
