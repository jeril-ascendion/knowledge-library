%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart TB

    %% ─── System under review ───
    SYSTEM([System Under Review])

    %% ─── Tier assignment ───
    TIER{Tier Assignment<br/>routine / moderate<br/>significant / critical}

    %% ─── Threat model (the foundation) ───
    THREATS[(Documented Threat Model<br/>STRIDE / attack trees<br/>actors &middot; assets &middot; vectors)]

    %% ─── Defense-in-depth layers ───
    subgraph LAYERS [Defense-in-Depth Layers]
        direction TB
        NETWORK[Network / Perimeter<br/>segmentation &middot; ingress/egress<br/>WAF &middot; DDoS]
        APP[Application<br/>input validation &middot; output encoding<br/>injection defenses]
        IDENTITY[Identity / Authentication<br/>MFA &middot; session management<br/>credential storage]
        AUTHZ[Authorisation / Access<br/>RBAC / ABAC &middot; least privilege<br/>privilege boundaries]
        DATA[Data / Encryption<br/>at-rest &middot; in-transit<br/>key management]
        MONITOR[Monitoring / Detection<br/>audit logging &middot; alerting<br/>anomaly detection]
        IR[Incident Response<br/>runbooks &middot; pen-test exercise<br/>recovery procedures]
    end

    %% ─── Attack surfaces (the attacker view) ───
    subgraph SURFACES [Attack Surface Enumeration]
        direction TB
        API[Public APIs<br/>per endpoint family]
        ADMIN[Admin Consoles<br/>privileged interfaces]
        INGRESS[Ingress Paths<br/>file upload &middot; webhooks<br/>email]
        THIRDPARTY[Third-Party Boundaries<br/>OAuth callbacks<br/>SSO integrations]
    end

    %% ─── Item tagging ───
    TAGS{Item Tagging<br/>compliance / security / both}

    %% ─── Review output ───
    OUTPUT[(Review Output<br/>per-layer pass/gap<br/>per-surface pass/gap)]

    %% ─── Calibration loop ───
    INCIDENT([Security Incident])
    PENTEST([Pen-Test / Disclosure])
    POSTREVIEW['Would checklist<br/>have caught this?']
    REVISION[Revision Queue<br/>versioned &middot; reviewed]

    %% ─── Flow ───
    SYSTEM --> TIER
    TIER --> THREATS
    THREATS -.maps to.-> LAYERS
    THREATS -.maps to.-> SURFACES

    LAYERS --> TAGS
    SURFACES --> TAGS
    TAGS --> OUTPUT

    %% Calibration
    INCIDENT --> POSTREVIEW
    PENTEST --> POSTREVIEW
    POSTREVIEW --> REVISION
    REVISION -.updates.-> LAYERS
    REVISION -.updates.-> SURFACES
    REVISION -.updates.-> THREATS

    %% ─── NODE STYLES ───
    style SYSTEM fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% Tier: emphasised
    style TIER fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410

    %% Threat model: emphasised (the foundation)
    style THREATS fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Defense layers: cream gradient (architectural depth)
    style NETWORK  fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style APP      fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style IDENTITY fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style AUTHZ    fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style DATA     fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style MONITOR  fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style IR       fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410

    %% Attack surfaces: amber (the attacker view)
    style API        fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style ADMIN      fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style INGRESS    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style THIRDPARTY fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Tags: emphasised (the architectural distinction)
    style TAGS fill:#FBEDE0,stroke:#C96330,stroke-width:2.2px,color:#3A2410

    %% Output: blue
    style OUTPUT fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Calibration: cooler
    style INCIDENT   fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410
    style PENTEST    fill:#F4E5DD,stroke:#A37050,stroke-width:1.8px,color:#3A2410
    style POSTREVIEW fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style REVISION   fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.8px,color:#2C4258

    %% ─── CLUSTER STYLES ───
    style LAYERS   fill:#FEF1E6,stroke:#D4A87A,stroke-width:1.4px,color:#3A2410
    style SURFACES fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
