classDiagram
    class NFRScorecard {
        +System system
        +Release release
        +Date assessedAt
        +Attribute[] attributes
        +produceTrend()
    }

    class Attribute {
        +String name
        +String iso25010Category
        +Target target
        +Score specifiedScore
        +Score validatedScore
        +Score operatingScore
        +Learning[] learnings
    }

    class Target {
        +String measure
        +Number value
        +String unit
        +String rationale
        +Date lastReviewed
    }

    class Score {
        +Integer level
        +Number measuredValue
        +Number deltaToTarget
        +Confidence confidence
    }

    class Learning {
        +String description
        +String impactOnTargets
        +Date capturedAt
    }

    class TradeOff {
        +String description
        +ADR justifyingAdr
        +Attribute[] affectedAttributes
    }

    NFRScorecard "1" *-- "many" Attribute : contains
    Attribute "1" *-- "1" Target : has
    Attribute "1" *-- "1..3" Score : carries
    Attribute "1" *-- "many" Learning : accumulates
    Attribute "1" ..> "many" TradeOff : participates in
