flowchart TD
    A["Event detected by monitoring or customer report"] --> B{"Event class"}

    B -->|"Service disruption"| C["AFASA disruption-notification path"]
    B -->|"Account takeover or scam"| D["AFASA scam-notification path"]
    B -->|"Routine operational event"| E["Standard incident-management"]
    B -->|"AML/CFT trigger"| F["AMLC suspicious-transaction path"]

    C --> C1{"Material<br/>service impact?"}
    C1 -->|"No"| E
    C1 -->|"Yes"| C2["BSP 2-hour notification clock starts"]
    C2 --> C3["Compose disruption notice with required fields"]
    C3 --> C4{"Authorized signatory<br/>available within 90min?"}
    C4 -->|"Yes"| C5["Submit to BSP via designated channel"]
    C4 -->|"No"| C6["Escalate to alternate signatory in on-call rotation"]
    C6 --> C5

    D --> D1["BSP 24-hour notification clock starts"]
    D1 --> D2["Customer affected account flagged"]
    D2 --> D3["Account-protection workflow triggered"]
    D3 --> D4["Compose AFASA notice with affected-customer count, scam type, controls invoked"]
    D4 --> D5["Submit to BSP within window"]

    F --> F1["STR drafted within prescribed window"]
    F1 --> F2["Submit to AMLC; cross-reference to BSP if applicable"]

    C5 --> G["Update regulatory-finding ledger"]
    D5 --> G
    E --> G
    F2 --> G

    G --> H["Trajectory review at next quarterly compliance forum"]
    H --> I["Architectural change scheduled if pattern detected"]

    style C2 fill:#fef3c7
    style D1 fill:#fef3c7
    style C5 fill:#d1fae5
    style D5 fill:#d1fae5
