classDiagram
    class ISMS {
        +Scope scope
        +Context organisationalContext
        +Date establishedAt
        +Date lastReviewed
        +Objective[] objectives
        +runPDCACycle()
        +produceManagementReview()
    }

    class RiskRegister {
        +Asset[] assets
        +Risk[] risks
        +Date lastReassessed
        +addRisk()
        +reassess()
    }

    class Risk {
        +String identifier
        +Threat threat
        +Vulnerability vulnerability
        +Impact impact
        +Likelihood likelihood
        +TreatmentDecision treatment
        +Owner owner
    }

    class Asset {
        +String identifier
        +String name
        +Classification classification
        +Owner owner
        +Risk[] associatedRisks
    }

    class StatementOfApplicability {
        +Control[] includedControls
        +Control[] excludedControls
        +String exclusionRationale
        +Date lastUpdated
        +linkToRisks()
    }

    class Control {
        +String annexAReference
        +String name
        +Theme theme
        +Risk[] mitigatesRisks
        +ImplementationOwner owner
        +Effectiveness measurement
    }

    class InternalAudit {
        +Date scheduledAt
        +Control[] scope
        +Finding[] findings
        +Auditor auditor
        +Independence verified
    }

    class ManagementReview {
        +Date heldAt
        +ReviewInput[] inputs
        +Decision[] decisions
        +Owner[] decisionOwners
    }

    class Finding {
        +String description
        +Severity severity
        +Decision decision
        +Owner owner
        +Date dueDate
        +TrajectoryEntry[] history
    }

    ISMS "1" *-- "1" RiskRegister : maintains
    ISMS "1" *-- "1" StatementOfApplicability : produces
    ISMS "1" *-- "many" InternalAudit : schedules
    ISMS "1" *-- "many" ManagementReview : conducts
    RiskRegister "1" *-- "many" Risk : contains
    RiskRegister "1" *-- "many" Asset : indexes
    Risk "1..*" --> "many" Asset : threatens
    StatementOfApplicability "1" *-- "many" Control : selects
    Control "many" --> "many" Risk : mitigates
    InternalAudit "1" *-- "many" Finding : produces
    ManagementReview "many" --> "many" Finding : reviews
