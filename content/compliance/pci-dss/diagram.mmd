    CARDHOLDER {
        string identifier
        string name
    }
    PAN {
        string fullValue
        boolean storedOnlyEncrypted
        date capturedAt
    }
    SAD {
        string track
        string cvv
        string pin
        boolean prohibitedFromStorage
