        string identifier
        string scopeRationale
        date lastSegmentationTest
    }
    ENCRYPTION_KEY {
        string keyId
        string algorithm
        string custodianRole
        date nextRotation
    }
    FINDING_LEDGER {
        string findingId
        string decision
        string owner
        date dueDate
    }
