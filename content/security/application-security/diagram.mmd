%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart LR

    %% ─── Design-time security ───
    subgraph DESIGN [Design &mdash; threat modelling]
        direction TB
        TM[Threat Model<br/>STRIDE &middot; attack trees]
        REQ[Security Requirements<br/>authn &middot; authz &middot; audit]
    end

    %% ─── Build pipeline with embedded security ───
    subgraph BUILD [Build &mdash; secure-by-construction]
        direction TB
        CODE[Source Code]
        SAST[SAST<br/>static analysis]
        SBOM[SBOM Generation<br/>CycloneDX / SPDX]
        DEPSCAN[Dependency Scan<br/>known CVEs]
        SIGN[Artefact Signing<br/>Sigstore / SLSA]
    end

    %% ─── Deployment with verification ───
    subgraph TEST [Pre-prod &mdash; dynamic verification]
        direction TB
        DAST[DAST<br/>running-app probe]
        IAST[IAST<br/>instrumented runtime]
    end

    %% ─── Runtime ───
    subgraph RUN [Runtime &mdash; production]
        direction TB
        WAF[WAF / Edge<br/>perimeter rules]
        APP[Application<br/>validated inputs<br/>encoded outputs]
        TELE[Security Telemetry<br/>RASP &middot; audit log]
    end

    %% ─── Findings triage ───
    BACKLOG[/Findings Backlog<br/>severity SLA &middot; owner/]

    %% ─── Flow ───
    TM --> REQ
    REQ --> CODE
    CODE --> SAST
    CODE --> SBOM
    SBOM --> DEPSCAN
    SAST --> SIGN
    DEPSCAN --> SIGN
    SIGN --> DAST
    DAST --> IAST
    IAST --> WAF
    WAF --> APP
    APP --> TELE

    %% ─── Findings flow ───
    SAST -.findings.-> BACKLOG
    DEPSCAN -.findings.-> BACKLOG
    DAST -.findings.-> BACKLOG
    IAST -.findings.-> BACKLOG
    TELE -.alerts.-> BACKLOG
    BACKLOG -.feeds back.-> TM

    %% ─── NODE STYLES ───
    %% Design: blue (intent)
    style TM  fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style REQ fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Build: amber (construction)
    style CODE    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style SAST    fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
