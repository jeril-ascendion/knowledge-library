    style DEPSCAN fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style SIGN    fill:#FEF3C7,stroke:#C96330,stroke-width:2px,color:#5C4316

    %% Pre-prod: cooler grey-blue (verification)
    style DAST fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style IAST fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258

