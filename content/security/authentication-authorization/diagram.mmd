%%{init:{'theme':'base','themeVariables':{'fontSize':'14px','fontFamily':'IBM Plex Sans, system-ui, sans-serif','primaryColor':'#DBEAFE','primaryTextColor':'#1e3a5f','primaryBorderColor':'#2563EB','lineColor':'#374151','clusterBkg':'#F9FAFB','clusterBorder':'#D1D5DB','edgeLabelBackground':'#FFFFFF'},'flowchart':{'curve':'orthogonal','padding':30,'nodeSpacing':65,'rankSpacing':75,'useMaxWidth':true}}}%%
flowchart LR

    %% ─── User and identity provider ───
    USER([User])

    subgraph IDP_SIDE [Identity Provider &mdash; federated AuthN]
        direction TB
        IDP[OIDC / SAML IdP<br/>Auth0 / Okta / Azure AD]
        MFA[MFA<br/>passkey &middot; FIDO2 &middot; TOTP]
    end

    %% ─── Application boundary ───
    subgraph APP_SIDE [Application &mdash; consumes verified identity]
        direction TB
        EDGE[API Gateway / Edge<br/>token verification]
        APP[Application Logic<br/>requests PDP decision]
        RESOURCE[(Resources<br/>data &middot; actions)]
    end

    %% ─── PDP (separate decision point) ───
    PDP[Policy Decision Point<br/>OPA / Cedar / IAM<br/>declarative policy]

    %% ─── Identity governance ───
    subgraph IGA [Identity Governance]
        direction TB
        JML[Joiner-Mover-Leaver<br/>automation]
        REVIEW[Access Reviews<br/>quarterly attestation]
    end

    %% ─── Audit ───
    AUDIT[(Audit Log<br/>identity + policy + decision)]

    %% ─── Authentication flow ───
    USER -->|1. login| IDP
    IDP -->|2. challenge| MFA
    MFA -->|3. verified| IDP
    IDP -->|4. OIDC token| USER

    %% ─── Authorisation flow on each request ───
    USER -->|5. request + token| EDGE
    EDGE -->|6. verified identity| APP
    APP -->|7. may principal do action?| PDP
    PDP -->|8. allow / deny + reasoning| APP
    APP -->|9. permitted action| RESOURCE

    %% ─── Audit ───
    APP -.decision + reasoning.-> AUDIT

    %% ─── Governance lifecycle ───
    JML -.provisions / deprovisions.-> IDP
    REVIEW -.attests.-> IDP

    %% ─── NODE STYLES ───
    style USER fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF

    %% IdP side: blue (identity authority)
    style IDP fill:#DCEAFC,stroke:#2C5F9E,stroke-width:2px,color:#1A2840
    style MFA fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Application side: amber
    style EDGE     fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style APP      fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style RESOURCE fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316

    %% PDP: emphasised cream (policy authority)
    style PDP fill:#FBEDE0,stroke:#C96330,stroke-width:2.5px,color:#3A2410

    %% Governance: cooler grey-blue (lifecycle management)
    style JML    fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258
    style REVIEW fill:#E5ECF3,stroke:#5A7A9A,stroke-width:1.5px,color:#2C4258

    %% Audit: distinct grey
    style AUDIT fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.5px,color:#2C2C2C

    %% ─── CLUSTER STYLES ───
    style IDP_SIDE fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
    style APP_SIDE fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
    style IGA      fill:#F2F4F7,stroke:#9CB0C4,stroke-width:1.2px,color:#2C4258
