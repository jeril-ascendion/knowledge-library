flowchart LR

    %% ─── Consumers ───
    CONS([Web / Mobile / Partner])

    %% ─── Edge ───
    GW[API Gateway<br/>authn &middot; rate limit &middot; TLS]

    %% ─── Stateless service tier ───
    subgraph SVCS [Stateless services &mdash; horizontally scaled]
        direction TB
        S1[Service A<br/>Spring / Node / Python]
        S2[Service B]
        S3[Service C]
    end

    %% ─── Backing services ───
    subgraph BACKING [Backing services &mdash; the stateful tier]
        direction TB
        DB[(Database<br/>SQL / NoSQL)]
        CACHE[(Cache)]
        Q[/Message Queue/]
        OBJ[(Object Store)]
    end

    %% ─── Observability ───
    subgraph OBS [Observability]
        direction LR
        LOG[Structured Logs]
        TR[Traces<br/>OpenTelemetry]
        MET[Metrics]
    end

    %% ─── Security ───
    SECRETS[Secrets / KMS]
    IAM[IAM / IDP]

    %% ─── Flow ───
    CONS --> GW
    GW --> S1
    GW --> S2
    GW --> S3

    S1 --> DB
    S1 --> CACHE
    S2 --> Q
    S2 --> DB
    S3 --> OBJ
    S3 --> Q

    %% ─── Cross-cutting ───
    SVCS -.instrument.-> OBS
    SVCS -.authn / authz.-> IAM
    SVCS -.fetch.-> SECRETS

    %% ─── NODE STYLES ───
    style CONS fill:#4A90E2,stroke:#2C5F9E,stroke-width:2px,color:#FFFFFF
    style GW   fill:#FBEDE0,stroke:#C96330,stroke-width:2px,color:#3A2410

    %% Services: emphasised blue
    style S1 fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style S2 fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840
    style S3 fill:#DCEAFC,stroke:#2C5F9E,stroke-width:1.8px,color:#1A2840

    %% Backing: amber
    style DB    fill:#FEF3C7,stroke:#92722C,stroke-width:1.8px,color:#5C4316
    style CACHE fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316
    style Q     fill:#FBEDE0,stroke:#C96330,stroke-width:1.5px,color:#3A2410
    style OBJ   fill:#FEF3C7,stroke:#92722C,stroke-width:1.5px,color:#5C4316

    %% Observability: distinct grey
    style LOG fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.3px,color:#2C2C2C
    style TR  fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.3px,color:#2C2C2C
    style MET fill:#E8E8E2,stroke:#5C5C5C,stroke-width:1.3px,color:#2C2C2C

    %% Security: emphasized terracotta
    style SECRETS fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410
    style IAM     fill:#FBEDE0,stroke:#C96330,stroke-width:1.8px,color:#3A2410

    %% ─── CLUSTER STYLES ───
    style SVCS    fill:#EDF4FC,stroke:#A8C0DD,stroke-width:1.2px,color:#1A2840
    style BACKING fill:#FEF8E5,stroke:#D4C599,stroke-width:1.2px,color:#5C4316
    style OBS     fill:#F2F2EE,stroke:#A0A099,stroke-width:1.2px,color:#2C2C2C
