flowchart TD
    subgraph TRANSPORT["Transport Layer"]
        T1[TLS 1.3 minimum]
        T2[SPKI Hash Pinning + 2 backup pins]
        T3[Network Security Config / ATS]
        T4[Certificate Transparency Monitoring]
    end

    subgraph AUTH["Authentication & Authorization"]
        A1[OAuth 2.0 + PKCE — no client_secret]
        A2[Refresh Token Rotation RFC 6819]
        A3[Biometric reauth for sensitive ops]
        A4[Play Integrity / App Attest]
    end

    subgraph STORAGE["Data at Rest"]
        S1[EncryptedSharedPreferences / Keychain]
        S2[Hardware-backed Keystore — StrongBox / Secure Enclave]
        S3[SQLCipher / SwiftData Data Protection]
        S4[FLAG_SECURE / Background blur]
    end

    subgraph BINARY["Binary Hardening"]
        B1[R8 / Bitcode]
        B2[allowBackup false / debuggable false]
        B3[Root / Jailbreak detection signal]
        B4[Anti-tampering for MASVS-R]
    end

    subgraph SUPPLY["Supply Chain"]
        SC1[SBOM per release]
        SC2[Snyk / Dependabot scans]
        SC3[Lockfile pinned transitive deps]
    end

    T1 --> AUTH
    AUTH --> STORAGE
    STORAGE --> BINARY
    BINARY -.audited by.-> SUPPLY

