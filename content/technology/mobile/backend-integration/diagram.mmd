flowchart LR
    subgraph MOBILE["Mobile Clients"]
        M1[Android — OkHttp + Apollo / Retrofit]
        M2[iOS — URLSession / Apollo iOS]
    end

    subgraph EDGE["Edge / CDN"]
        E1[CloudFront / Cloudflare]
        E2[Brotli compression]
        E3[ETag — 304 Not Modified]
    end

    subgraph BFF["Mobile BFF"]
        B1[GraphQL Gateway]
        B2[Mobile-shaped REST aggregator]
        B3[MSV enforcement]
    end

    subgraph SERVICES["Microservices"]
        S1[Account Service]
        S2[Transaction Service]
        S3[Notification Service]
        S4[Profile Service]
    end

    subgraph PUSH["Push Channel"]
        P1[APNs HTTP/2]
        P2[FCM]
        P3[Payload: notification_id only]
    end

    subgraph STREAM["Streaming"]
        G1[gRPC bidirectional — chat / live]
    end

    M1 --> E1
    M2 --> E1
    E1 --> B1
    E1 --> B2
    B1 --> S1
    B1 --> S2
    B1 --> S3
    B2 --> S1
    B2 --> S4
    S3 --> P1
    S3 --> P2
    P1 -.delivers ID.-> M2
    P2 -.delivers ID.-> M1
    M1 -.fetches content.-> B2
    M2 -.fetches content.-> B2
    M1 --> G1
    M2 --> G1

