flowchart LR
    subgraph UI["UI Layer"]
        U1[Composable / SwiftUI View]
        U2[Optimistic UI update]
    end

    subgraph REPO["Repository"]
        R1[observe Flow / AsyncStream]
        R2[refresh — delta sync]
        R3[Outbox enqueue for writes]
    end

    subgraph LOCAL["Local — Source of Truth"]
        L1[Room / SwiftData]
        L2[Outbox table — pending writes]
        L3[Sync Watermark Store]
        L4[SQLCipher encryption]
    end

    subgraph BG["Background"]
        B1[WorkManager / BGAppRefreshTask]
        B2[Outbox Worker — idempotency keys]
        B3[Connectivity Manager / NWPathMonitor]
    end

    subgraph NET["Network"]
        N1[REST / GraphQL Backend]
    end

    U1 -.reads.-> R1
    R1 -.observes.-> L1
    U2 -.write.-> R3
    R3 --> L2
    R2 -.since=watermark.-> N1
    N1 -.delta + tombstones.-> R2
    R2 --> L1
    R2 --> L3
    B1 --> R2
    B2 --> L2
    B2 -.applies.-> N1
    B3 -.triggers.-> B1
    L1 -.uses.-> L4

    style L1 fill:#C96330,color:#fff
    style R1 fill:#DCEAFC,stroke:#3D6395,stroke-width:2px
    style B2 fill:#FBEDE0,stroke:#C96330,stroke-width:2px
